{
  "name": "typedoc-plugins",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "lerna run build",
    "lint": "pnpm -w eslint \"**/*.{ts,tsx,js,jsx}\" --max-warnings=0",
    "format": "pnpm -w prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "test": "vitest"
  },
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "apps/*",
    "plugins/*"
  ],
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/eslintrc": "3.3.5",
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lerna": "^9.0.5",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "typedoc": "^0.28.17",
    "typedoc-plugin-carbon-ads": "workspace:^",
    "typedoc-plugin-clarity": "workspace:^",
    "typedoc-plugin-google-ads": "workspace:^",
    "typedoc-plugin-keywords": "workspace:^",
    "typedoc-plugin-particles": "workspace:^",
    "typescript": "^5.9.3"
  }
}
